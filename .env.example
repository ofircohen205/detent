# Detent Docker environment variables
# Copy to .env and customize before running docker compose:
#   cp .env.example .env

# Proxy port (default: 7070)
PROXY_PORT=7070

# Log level: DEBUG | INFO | WARNING | ERROR
DETENT_LOG_LEVEL=INFO

# Workspace path mounted into the tools sidecar (default: current directory)
WORKSPACE_PATH=.

# Optional agent environment overrides (not read by the proxy container itself)
# Uncomment when pointing Claude Code / Cursor through Detent:
# ANTHROPIC_BASE_URL=http://localhost:7070
# OPENAI_BASE_URL=http://localhost:7070
